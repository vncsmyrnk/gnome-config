#!/usr/bin/env bash

# vim: set ft=sh:

# This leverages the GNOME Window Calls extension to raise opened applications via DBus.
# The extension is required for this script to work as intended.
# Extension: https://github.com/ickyicky/window-calls

bustctl_dbus_list_windows_ids_ordered() {
  busctl --user call \
    org.gnome.Shell \
    /org/gnome/Shell/Extensions/Windows \
    org.gnome.Shell.Extensions.Windows \
    List \
    --json=short
}

bustctl_dbus_activate_window() {
  busctl --user call \
    org.gnome.Shell \
    /org/gnome/Shell/Extensions/Windows \
    org.gnome.Shell.Extensions.Windows \
    Activate \
    u "$1"
}

help() {
  echo "Usage: gnome-focus-recent-window [--steps <steps>] [--current-wm-class] [--exclude-regexp <regexp>]"
  echo ""
  echo "Leverages GNOME Window Calls extension to raise opened application windows via DBus."
  echo ""
  echo "The default behavior is switching to the last application opened ignoring other instances."
  echo "The \"--current-wm-class\" makes it consider only other instances of the current opened application."
}

focus_recent() {
  steps="$1"
  exclude_window_regexp="$2"

  windows_list=$(
    bustctl_dbus_list_windows_ids_ordered |
      jq -r '.data[0]'
  )

  current_opened_wm_class=$(
    jq -r '.[-1] | .wm_class' <<<"$windows_list"
  )
  exclude_window_regexp="$exclude_window_regexp|$current_opened_wm_class"

  window_id=$(
    jq -r --arg regexp "$exclude_window_regexp" '.[:length-1] | .[] | select(.wm_class | test($regexp; "i") | not) | .id' <<<"$windows_list" |
      tac |
      grep -v "$exclude_window_regexp" |
      sed -n "${steps}p"
  )

  if [[ -z "$window_id" ]]; then
    exit 1
  fi

  bustctl_dbus_activate_window "$window_id"
}

focus_recent_instance() {
  steps="$1"

  windows_list=$(
    bustctl_dbus_list_windows_ids_ordered |
      jq -r '.data[0]'
  )

  current_opened_wm_class=$(
    jq -r '.[-1] | .wm_class' <<<"$windows_list"
  )

  window_id=$(
    jq -r --arg wmClass "$current_opened_wm_class" \
      '.[:length-1] | .[] | select(.wm_class == $wmClass) | .id' \
      <<<"$windows_list" |
      tac |
      sed -n "${steps}p"
  )

  if [ -z "$window_id" ]; then
    exit 1
  fi

  bustctl_dbus_activate_window "$window_id"
}

main() {
  steps="1"
  exclude_window_regexp="^$"
  current_wm_class=false
  while [[ $# -gt 0 ]]; do
    case $1 in
    -s | --steps)
      steps="$2"
      shift 2
      ;;
    --steps=*)
      steps="${1#*=}"
      shift
      ;;
    --current-wm-class)
      current_wm_class=true
      shift
      ;;
    --exclude-regexp)
      exclude_window_regexp="$2"
      shift 2
      ;;
    --exclude-regexp=*)
      exclude_window_regexp="${1#*=}"
      shift
      ;;
    -h | --help)
      help
      exit 0
      ;;
    *)
      steps="$1"
      shift
      ;;
    esac
  done

  if "$current_wm_class"; then
    focus_recent_instance "$steps"
    exit 0
  fi

  focus_recent "$steps" "$exclude_window_regexp"
}

main "$@"
