#!/usr/bin/env bash

# vim: set ft=sh:

GNOME_CONFIG_PATH="${GNOME_CONFIG_PATH:-""}"

help() {
  echo "Usage: gnome-config <command> <path>"
  echo ""
  echo "Available commands:"
  echo " apply"
  echo " reset"
  echo ""
  echo "Applies GNOME settings via dconf. Default settings are set if no path is informed."
}

apply() {
  config_path="$1"
  configuration_files=($(
    find "$config_path" -type f
  ))
  for configuration in "${configuration_files[@]}"; do
    echo "Applying $(basename "$configuration")"
    dconf load / <"$configuration"
  done
}

reset() {
  config_path="$1"
  configuration_files=($(
    grep -h "^\[org\/gnome" "$config_path/"* |
      sort -u |
      sed -e 's/\[/\//g' -e 's/\]/\//g'
  ))
  for configuration in "${configuration_files[@]}"; do
    echo "Reseting $configuration"
    dconf reset -f "$configuration"
  done
}

main() {
  if [[ -z "$1" ]]; then
    help
    exit 0
  fi

  config_path="$GNOME_CONFIG_PATH"
  if [[ -n "$2" ]]; then
    config_path="$2"
  fi

  if [[ -z "$config_path" ]]; then
    echo "Config path not set."
    exit 1
  fi

  if [[ "$1" = "apply" ]]; then
    apply "$config_path"
  elif [[ "$1" = "reset" ]]; then
    reset "$config_path"
  else
    help
    exit 1
  fi
}

main "$@"
